# ============================================================
# Kahlo ERP — variables d'environnement (développement local)
# Copiez ce fichier vers .env puis adaptez uniquement les valeurs nécessaires.
# ============================================================

# ------------------------------------------------------------
# Docker / Infrastructure
# ------------------------------------------------------------
POSTGRES_PASSWORD=kahlo_dev_2024
REDIS_PASSWORD=kahlo_redis_dev
HTTP_PORT=80
HTTPS_PORT=443
# Bind nginx sur loopback par défaut (reverse proxy externe recommandé)
BIND_HOST=127.0.0.1

# ------------------------------------------------------------
# Authentification / sécurité
# ------------------------------------------------------------
# Clé de signature JWT (obligatoire en production)
SECRET_KEY=dev-secret-key-change-in-production
# Username de l'admin bootstrap
APP_USERNAME=kahlo
# Mot de passe initial admin (créé/forcé au démarrage selon ADMIN_FORCE_RESET)
APP_DEFAULT_PASSWORD=changeme
# Optionnel: hash bcrypt admin (hors Docker Compose recommandé)
# APP_PASSWORD_HASH=
# Force la réinitialisation du compte admin au démarrage
ADMIN_FORCE_RESET=false
# Durée de session JWT (heures)
SESSION_HOURS=8
# Protection brute-force login
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
# Optionnel: chemin du .env depuis le conteneur backend
ENV_FILE_PATH=/app/.env

# ------------------------------------------------------------
# CORS / Frontend
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost

# ------------------------------------------------------------
# PostgreSQL / Redis internes (normalement laissés par défaut)
# ------------------------------------------------------------
DATABASE_URL=postgresql://kahlo:${POSTGRES_PASSWORD}@db:5432/kahlo
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ------------------------------------------------------------
# SumUp
# ------------------------------------------------------------
SUMUP_API_KEY=
SUMUP_CLIENT_ID=
SUMUP_CLIENT_SECRET=
SUMUP_WEBHOOK_SECRET=
SUMUP_MERCHANT_EMAIL=bonjour@kahlocafe.fr
SUMUP_MODE=sandbox

# ------------------------------------------------------------
# Brevo
# ------------------------------------------------------------
BREVO_API_KEY=
BREVO_FROM_EMAIL=bonjour@kahlocafe.fr
BREVO_FROM_NAME=Kahlo Café
BREVO_LIST_CLIENTS=3
BREVO_LIST_VIP=
BREVO_LIST_RELANCE=7
BREVO_TPL_ANNIVERSAIRE=1
BREVO_TPL_CONFIRMATION=2
BREVO_TPL_PRETE=3
BREVO_TPL_RELANCE=
BREVO_ENVOI_ANNIVERSAIRE=true
BREVO_ENVOI_RELANCE=true
BREVO_ENVOI_CONFIRMATION=true
BREVO_ENVOI_PRETE=true

# ------------------------------------------------------------
# IA Gemini
# ------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
IA_ANALYSE_MARCHE=true
IA_SUGGESTION_STOCK=true
IA_FICHE_PRODUIT=true
IA_ANALYSE_DASHBOARD=false

# ------------------------------------------------------------
# Calendrier (CalDAV + Google)
# ------------------------------------------------------------
CALDAV_BASE_URL=http://caldav:5232
CALDAV_USER=kahlo
CALDAV_PASSWORD=changeme
CALDAV_INTERVAL=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SYNC_MARCHES=true
SYNC_COMMANDES=true
SYNC_FOURNISSEURS=false

# ------------------------------------------------------------
# Paramètres métier
# ------------------------------------------------------------
BOUTIQUE_NOM=Kahlo Café
BOUTIQUE_VILLE=Lyon, France
BOUTIQUE_EMAIL=bonjour@kahlocafe.fr
BOUTIQUE_TEL=
BOUTIQUE_SIRET=
DEVISE=EUR
TIMEZONE=Europe/Paris
FORMAT_DATE=dd/MM/yyyy
OBJECTIF_CA_MENSUEL=3500

# ------------------------------------------------------------
# Stock / CRM
# ------------------------------------------------------------
STOCK_SEUIL_ALERTE=3
STOCK_ALERTE_DLC_JOURS=30
STOCK_LOT_VIEUX_JOURS=90
STOCK_FIFO_AUTO=true
STOCK_ALERTE_RUPTURE=true
STOCK_BON_COMMANDE_AUTO=false
STOCK_QTE_MIN_REAPPRO=5
CRM_TAMPONS_MAX=10
CRM_RECOMPENSE_LABEL=1 café offert (250g au choix)
CRM_INACTIVITE_JOURS=45
CRM_ANNIV_JOURS_AVANT=14
CRM_VIP_CA_SEUIL=200
CRM_VIP_AUTO=true

# ------------------------------------------------------------
# Sauvegarde / facturation
# ------------------------------------------------------------
BACKUP_AUTO=true
BACKUP_FREQ=daily
BACKUP_RETENTION_JOURS=30
BACKUP_PATH=/backups/kahlo
FACTURES_DIR=/app/factures
SESSION_LONGUE=true
