# Kahlo Café ERP — Variables d'environnement (DEV)

# PostgreSQL
POSTGRES_PASSWORD=kahlo_dev_2024

# ============================================================
# Auth & Sécurité
# ============================================================
# SECRET_KEY : clé de signature JWT. En dev, une clé temporaire est générée.
# En production, générez une clé unique : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Admin initial — créé au premier démarrage si la table utilisateurs est vide.
APP_USERNAME=kahlo

# Mot de passe admin : utiliser APP_DEFAULT_PASSWORD (recommandé avec Docker)
# NE PAS utiliser APP_PASSWORD_HASH avec Docker Compose car les $ sont interprétés.
APP_DEFAULT_PASSWORD=changeme

# Pour reset admin : mettre ADMIN_FORCE_RESET=true et redémarrer.
# L'admin sera recréé/mis à jour avec les identifiants ci-dessus.
# IMPORTANT : remettre à false après le reset.
# ADMIN_FORCE_RESET=false

SESSION_HOURS=8

# Rate limiting login
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=300

# ============================================================
# SumUp (laisser vide en dev si pas de compte)
# ============================================================
SUMUP_API_KEY=
SUMUP_CLIENT_ID=
SUMUP_CLIENT_SECRET=
SUMUP_WEBHOOK_SECRET=

# ============================================================
# Google Gemini AI
# ============================================================
GEMINI_API_KEY=

# ============================================================
# CORS (séparés par des virgules)
# ============================================================
CORS_ORIGINS=http://localhost:3000,https://erp.kahlocafe.fr

# ============================================================
# Brevo (emails)
# ============================================================
BREVO_API_KEY=
BREVO_FROM_EMAIL=bonjour@kahlocafe.fr
BREVO_FROM_NAME=Kahlo Café
BREVO_LIST_CLIENTS=3
BREVO_LIST_RELANCE=7
BREVO_TPL_ANNIVERSAIRE=1
BREVO_TPL_CONFIRMATION=2
BREVO_TPL_PRETE=3

# ============================================================
# Google OAuth
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# CalDAV (Radicale)
# ============================================================
CALDAV_USER=kahlo
CALDAV_PASSWORD=changeme

# ============================================================
# Ports (défaut: 80/443)
# ============================================================
# HTTP_PORT=80
# HTTPS_PORT=443
